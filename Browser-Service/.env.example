# Browser-Service 环境变量配置

# ==================== 服务配置 ====================
# 服务端口
BROWSER_SERVICE_PORT=9500
BROWSER_SERVICE_HOST=0.0.0.0

# 日志级别: DEBUG/INFO/WARNING/ERROR
LOG_LEVEL=INFO

# ==================== 浏览器池配置 ====================
# 浏览器池大小（最大同时运行的浏览器实例数）
BROWSER_POOL_SIZE=5

# CDP 调试端口范围
CDP_PORT_START=9222
CDP_PORT_END=9321

# 默认无头模式（容器中建议设为 true）
HEADLESS=false

# 自定义浏览器路径（为空则自动检测 Chrome/Edge）
CUSTOM_BROWSER_PATH=

# 浏览器启动超时时间（秒）
BROWSER_LAUNCH_TIMEOUT=30

# 浏览器数据持久化目录（Cookie/登录态保存位置）
BROWSER_DATA_DIR=./browser_data

# ==================== 健康检查与自动恢复 ====================
# 心跳间隔（秒），每 N 秒对所有 ready 实例执行健康检查
HEARTBEAT_INTERVAL=15

# 是否启用自动重启（连续 N 次健康检查失败后自动重启浏览器）
AUTO_RESTART_ENABLED=true

# 连续健康检查失败阈值（达到后自动重启浏览器实例）
MAX_HEALTH_FAIL_COUNT=3

# 僵尸实例清理间隔（秒），清理 stopped 超过 5 分钟的实例元数据
STALE_CLEANUP_INTERVAL=60

# CDP WebSocket 保活 ping 间隔（秒），通过 HTTP /json/version 保持连接活跃
WS_PING_INTERVAL=30

# ==================== 浏览器默认参数 ====================
# 浏览器默认视口大小
BROWSER_DEFAULT_VIEWPORT_WIDTH=1920
BROWSER_DEFAULT_VIEWPORT_HEIGHT=1080

# Chrome 额外启动参数 (逗号分隔)
# CHROME_EXTRA_ARGS="--disable-gpu,--disable-web-security"
CHROME_EXTRA_ARGS=
