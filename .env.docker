# ==========================================
# MediaCrawler Docker 环境变量配置
# ==========================================

# ---------- MySQL ----------
MYSQL_HOST_PORT=3306
MYSQL_ROOT_PASSWORD=123456
MYSQL_DATABASE=media_crawler

# ---------- Redis ----------
REDIS_HOST_PORT=6380
REDIS_PASSWORD=123456

# ---------- 服务端口映射 ----------
DATA_API_PORT=8080
CRAWLER_PORT=8081
WEB_PORT=10002

# ---------- Crawler-Service 配置 ----------
# CDP 模式（Docker 中强制无头）
ENABLE_CDP_MODE=True
CDP_HEADLESS=True
